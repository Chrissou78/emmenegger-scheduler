{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "outDir": ".vercel/output",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@emmenegger/shared/*": ["shared/*"]
    }
  },
  "include": ["api/**/*", "backend/src/**/*", "shared/**/*"],
  "exclude": ["node_modules", "frontend"]
}
