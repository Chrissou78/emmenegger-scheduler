{
  "projects": [
    {
      "name": "backend",
      "rootDirectory": "backend",
      "buildCommand": "npm run build",
      "outputDirectory": "dist",
      "framework": "nodejs"
    },
    {
      "name": "frontend",
      "rootDirectory": "frontend",
      "buildCommand": "npm run build",
      "outputDirectory": "dist",
      "framework": "vite",
      "env": {
        "VITE_API_URL": "@api_url"
      }
    }
  ]
}
