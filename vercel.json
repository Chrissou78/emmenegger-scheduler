{
  "buildCommand": "echo 'Building monorepo'",
  "outputDirectory": ".",
  "projects": [
    {
      "name": "backend",
      "rootDirectory": "backend",
      "buildCommand": "npm run build",
      "outputDirectory": "dist",
      "framework": "nodejs",
      "env": {
        "NODE_ENV": "production"
      }
    },
    {
      "name": "frontend",
      "rootDirectory": "frontend",
      "buildCommand": "npm run build",
      "outputDirectory": "dist",
      "framework": "vite",
      "env": {
        "VITE_API_URL": "@api_url"
      }
    }
  ]
}